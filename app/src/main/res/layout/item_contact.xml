<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <TextView android:id="@+id/tvAvatar"
        android:textSize="18sp" android:textColor="#FFFFFF" android:textStyle="bold"
        android:gravity="center" android:background="@color/accent"
        android:layout_width="44dp" android:layout_height="44dp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:layout_marginStart="12dp">
        <TextView android:id="@+id/tvName" android:textSize="15sp" android:textStyle="bold"
            android:textColor="@color/text_main"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvStatus" android:textSize="12sp" android:textColor="@color/muted"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>