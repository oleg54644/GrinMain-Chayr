<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="start" android:padding="4dp">
    <LinearLayout android:background="@color/bubble_them" android:padding="10dp"
        android:orientation="vertical" android:maxWidth="260dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content">
        <TextView android:id="@+id/tvSender" android:textColor="@color/accent"
            android:textSize="12sp" android:textStyle="bold"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvMessageText" android:textColor="@color/text_main"
            android:textSize="15sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvMessageTime" android:textColor="@color/muted"
            android:textSize="10sp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>