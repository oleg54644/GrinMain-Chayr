<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">

    <!-- Remote video (fullscreen) -->
    <org.webrtc.SurfaceViewRenderer android:id="@+id/remoteRenderer"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Remote group videos container -->
    <LinearLayout android:id="@+id/remotesContainer"
        android:layout_width="match_parent" android:layout_height="200dp"
        android:orientation="horizontal" android:visibility="gone"/>

    <!-- Local video (PiP) -->
    <org.webrtc.SurfaceViewRenderer android:id="@+id/localRenderer"
        android:layout_width="120dp" android:layout_height="160dp"
        android:layout_gravity="top|end" android:layout_margin="16dp"
        android:visibility="gone"/>

    <!-- Call info overlay -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="center_horizontal"
        android:layout_gravity="top" android:paddingTop="80dp">
        <TextView android:id="@+id/tvCallTitle"
            android:textSize="28sp" android:textColor="#FFFFFF" android:textStyle="bold"
            android:gravity="center"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvCallStatus"
            android:textSize="16sp" android:textColor="#CCFFFFFF" android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <Chronometer android:id="@+id/tvCallTimer"
            android:textSize="14sp" android:textColor="#99FFFFFF" android:gravity="center"
            android:visibility="gone" android:layout_marginTop="4dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Incoming panel -->
    <LinearLayout android:id="@+id/incomingPanel"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:layout_gravity="bottom" android:layout_marginBottom="80dp"
        android:visibility="gone">
        <ImageButton android:id="@+id/btnReject"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:backgroundTint="@color/red_call" android:tint="#FFFFFF"
            android:layout_width="72dp" android:layout_height="72dp" android:layout_marginEnd="40dp"/>
        <ImageButton android:id="@+id/btnAccept"
            android:src="@android:drawable/ic_menu_call"
            android:backgroundTint="@color/green" android:tint="#FFFFFF"
            android:layout_width="72dp" android:layout_height="72dp"/>
    </LinearLayout>

    <!-- Call controls -->
    <LinearLayout android:id="@+id/callControls"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center"
        android:layout_gravity="bottom" android:layout_marginBottom="50dp"
        android:visibility="gone">
        <ImageButton android:id="@+id/btnMute"
            android:src="@android:drawable/ic_btn_speak_now"
            android:backgroundTint="@color/panel" android:tint="#FFFFFF"
            android:layout_width="60dp" android:layout_height="60dp" android:layout_margin="10dp"/>
        <ImageButton android:id="@+id/btnEndCall"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:backgroundTint="@color/red_call" android:tint="#FFFFFF"
            android:layout_width="72dp" android:layout_height="72dp" android:layout_margin="10dp"/>
        <ImageButton android:id="@+id/btnCamera"
            android:src="@android:drawable/ic_menu_camera"
            android:backgroundTint="@color/panel" android:tint="#FFFFFF"
            android:layout_width="60dp" android:layout_height="60dp" android:layout_margin="10dp"/>
        <ImageButton android:id="@+id/btnSwitchCam"
            android:src="@android:drawable/ic_menu_rotate"
            android:backgroundTint="@color/panel" android:tint="#FFFFFF"
            android:layout_width="60dp" android:layout_height="60dp" android:layout_margin="10dp"/>
    </LinearLayout>
</FrameLayout>